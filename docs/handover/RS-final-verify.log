  migration-down-check:
    name: Migrations (down check)
    runs-on: ubuntu-latest
    timeout-minutes: 5
    steps:
      - uses: actions/checkout@v4
        with:
          fetch-depth: 0
      - name: Check PR-added .up.sql have matching .down.sql
        run: |
          BASE=$(git merge-base origin/main HEAD 2>/dev/null || echo "HEAD~1")

