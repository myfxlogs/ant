--- Step 2: hashArgon2id 签名变更 ---
Before:
  func hashArgon2id(password string) string {

After:
  func hashArgon2id(password string) (string, error) {

--- Step 3: panic 改为 error return ---
Before:
  if _, err := rand.Read(salt); err != nil {
      panic("crypto/rand failed: " + err.Error())
  }

After:
  if _, err := rand.Read(salt); err != nil {
      return "", fmt.Errorf("crypto/rand: %w", err)
  }

--- Step 4: return 语句追加 nil error ---
Before:
  return fmt.Sprintf("$argon2id$v=19$m=%d,t=%d,p=%d$%s$%s", ...)

After:
  return fmt.Sprintf("$argon2id$v=19$m=%d,t=%d,p=%d$%s$%s", ...), nil

--- Step 5: Register 调用方适配 ---
Before:
  hash := hashArgon2id(m.Password)
  _, err := s.pg.Exec(ctx, ...)

After:
  hash, err := hashArgon2id(m.Password)
  if err != nil {
      s.log.Error("Register: hash password", zap.Error(err))
      return nil, connect.NewError(connect.CodeInternal, err)
  }
  _, err = s.pg.Exec(ctx, ...)

